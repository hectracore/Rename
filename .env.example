# ── DATABASE ─────────────────────────────────────────────────

# MongoDB connection string - Python 4.7+
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MAIN_URI=mongodb+srv://renamebot:renamebot@cluster0.xt9gzs7.mongodb.net/?appName=Cluster0


# ── ACCESS CONTROL ───────────────────────────────────────────

# Telegram User ID of the bot owner.
CEO_ID=6161553871

# Comma-separated Telegram User IDs of additional admins.
ADMIN_IDS=6161553871


# ── METADATA ─────────────────────────────────────────────────
TMDB_API_KEY=d2f23cc2f09bb217e31713f59d37676d


# ── MODE ─────────────────────────────────────────────────────

# Controls who can use the bot:
#   False (default) → Private Mode: only CEO + ADMIN_IDS can use the bot.
#                     One global set of settings for everyone.
#   True            → Public Mode: anyone on Telegram can use the bot.
#                     Each user gets their own personal settings profile.
#
# ⚠️  Choose your mode before first launch and stick with it -
#     the database structure differs significantly between modes.
PUBLIC_MODE=

# Set to True to enable verbose callback and handler logging. Keep False in production.
DEBUG_MODE=False
